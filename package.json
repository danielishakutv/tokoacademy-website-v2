{
  "name": "tokoacademy-website",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "reload:pm2": "pm2 reload tokoacademy-web --update-env",
    "logs:pm2": "pm2 logs tokoacademy-web",
    "deploy:pm2": "git pull origin master && npm ci && npm run build && (pm2 reload tokoacademy-web --update-env || pm2 start ecosystem.config.cjs --env production)",
    "export": "next build && next export",
    "lint": "next lint"
  },
  "dependencies": {
    "@iconify/react": "^4.1.1",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
